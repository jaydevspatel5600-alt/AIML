# Copy this file to ".env" and adjust values if needed.

# Folder where uploaded documents are stored
UPLOAD_DIR=data/uploads

# Folder where the Chroma vector database persists its files
CHROMA_DIR=data/chroma_db

# Embedding model (downloaded automatically the first time you run the app)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Local LLM model name as pulled in Ollama (see README "Install Ollama" section)
# Good options: "qwen2.5:7b"  "llama3.1:8b"  "gemma2:9b"
OLLAMA_MODEL=qwen2.5:7b

# Ollama server address (default when installed locally)
OLLAMA_HOST=http://localhost:11434

# Backend API address (used by the Streamlit frontend)
API_BASE_URL=http://localhost:8000
